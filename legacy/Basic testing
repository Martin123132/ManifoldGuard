# 1) LOAD MODEL
# ----------------
model = SentenceTransformer("all-MiniLM-L6-v2")

# ----------------
# 2) RESPONSES
# ----------------
responses = [
    "The capital of France is Paris.",
    "Paris is the capital city of France.",
    "France's capital is Paris.",
    "The capital of France is Lyon.",     # hallucination
    "The capital of France is London."    # hallucination
]

embeddings = model.encode(responses)

# MTS curvature strength (Γ in your notation)
Gamma = 1.0

# ----------------
# 3) MTS GEOMETRIC MEDIAN (WEISZFELD)
# ----------------
def mts_geometric_median(X, eps=1e-7, max_iter=2000):
    y = np.mean(X, axis=0)
    for _ in range(max_iter):
        d = np.linalg.norm(X - y, axis=1)
        d = np.maximum(d, eps)
        w = 1.0 / d
        y_new = np.sum(X * w[:, None], axis=0) / np.sum(w)
        if np.linalg.norm(y_new - y) < eps:
            return y_new
        y = y_new
    return y

# ----------------
# 4) MTS LEAVE-ONE-OUT CURVATURE SHOCK
# ----------------
mts_shocks = []

for i in range(len(embeddings)):
    others = np.delete(embeddings, i, axis=0)
    mts_center = mts_geometric_median(others)
    shock = Gamma * np.linalg.norm(embeddings[i] - mts_center) ** 2
    mts_shocks.append(shock)

mts_shocks = np.array(mts_shocks)

# ----------------
# 5) ROBUST MTS THRESHOLD (MEDIAN + k*MAD)
# ----------------
def mts_robust_threshold(values, k=3.0, eps=1e-12):
    med = np.median(values)
    mad = np.median(np.abs(values - med)) + eps
    return med + k * mad, med, mad

threshold, median, mad = mts_robust_threshold(mts_shocks)

# ----------------
# 6) REPORT
# ----------------
print("\n--- MTS LEAVE-ONE-OUT GEOMETRIC REPORT ---")
