import numpy as np
from sentence_transformers import SentenceTransformer

# ----------------
# 1) LOAD MODEL
# ----------------
model = SentenceTransformer("all-MiniLM-L6-v2")

Gamma = 1.0

# ----------------
# 2) STABLE REFERENCE SET
# ----------------
stable_sentences = [
    "The capital of France is Paris.",
    "Paris is the capital city of France.",
    "France's capital is Paris."
]

stable_embeddings = model.encode(stable_sentences)
stable_center = np.median(stable_embeddings, axis=0)

# ----------------
# 3) MTS TOKEN SHOCK ANALYSIS
# ----------------
def mts_token_shocks(sentence, reference_center):
    words = sentence.split()
    base_emb = model.encode([sentence])[0]
    base_dist = np.linalg.norm(base_emb - reference_center)

    shocks = []

    for i, word in enumerate(words):
        reduced = " ".join(w for j, w in enumerate(words) if j != i)
        red_emb = model.encode([reduced])[0]
        red_dist = np.linalg.norm(red_emb - reference_center)

        # Positive = removing this word reduces curvature
        shock = max(0.0, base_dist - red_dist)
        shocks.append(shock)

    return words, np.array(shocks)

# ----------------
# 4) MTS SELF-CORRECTOR
# ----------------
def mts_self_correct(sentence, reference_center, replacement="Paris", threshold=0.05):
    words, shocks = mts_token_shocks(sentence, reference_center)
    max_shock = shocks.max()

    print(f"\nOriginal: {sentence}")
    print(f"Max token shock: {max_shock:.4f}")

    if max_shock < threshold:
        print("✅ Sentence is already MTS-stable.")
        return sentence

    idx = shocks.argmax()
    bad_word = words[idx]

    print(f"🚨 Shock source: '{bad_word}'")

    corrected = words.copy()
    corrected[idx] = replacement
    corrected_sentence = " ".join(corrected)

    print(f"🔧 Corrected: {corrected_sentence}")

    return corrected_sentence

# ----------------
# 5) TEST CASES
# ----------------
tests = [
    "The capital of France is London",
    "The capital of France is Lyon"
]

for t in tests:
    mts_self_correct(t, stable_center)

