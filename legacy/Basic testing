from scipy.linalg import solve_banded

# 1. GENERATE "CHAOTIC" DATA (Simulated Volatile Stock)
np.random.seed(42)
n_days = 500
x = np.linspace(0, 10, n_days)
dx = x[1] - x[0]

# Base trend + high-frequency noise (the "shocks")
base_price = 100 + 10 * np.sin(x) + 2 * x
noise = np.random.normal(0, 5, n_days)
u_noisy = base_price + noise

# 2. MBT-5 SOLVER PARAMETERS
dt = 0.01        # "Time" step for the smoothing evolution
Gamma = 0.5      # MBT-5 Curvature Strength (Increase for smoother results)
