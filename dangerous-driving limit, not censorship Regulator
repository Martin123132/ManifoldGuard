import numpy as np
import ipywidgets as widgets
from IPython.display import display, HTML, clear_output
from sentence_transformers import SentenceTransformer

# ============================================================
# 1. UNIVERSAL AI CLIENT
# ============================================================
class UniversalAIClient:
    def __init__(self):
        self.provider = None
        self.client = None
        self.model_name = None

    def setup_openai(self, api_key, model="gpt-5.1"):
        import openai
        self.client = openai.OpenAI(api_key=api_key)
        self.provider = "openai"
        self.model_name = model

    def setup_anthropic(self, api_key, model="claude-sonnet-4-5"):
        import anthropic
        self.client = anthropic.Anthropic(api_key=api_key)
        self.provider = "anthropic"
        self.model_name = model

    def call_ai(self, prompt, system_prompt):
        try:
            if self.provider == "openai":
                res = self.client.chat.completions.create(
                    model=self.model_name,
                    messages=[
                        {"role": "system", "content": system_prompt},
                        {"role": "user", "content": prompt},
                    ],
                )
                return res.choices[0].message.content

            if self.provider == "anthropic":
                res = self.client.messages.create(
                    model=self.model_name,
                    max_tokens=800,
                    system=system_prompt,
                    messages=[{"role": "user", "content": prompt}],
                )
                return res.content[0].text
        except Exception as e:
            return f"❌ Error: {e}"


# ============================================================
# 2. ZERO-BOX MBT-5 SAFETY + STABILITY ENGINE
# ============================================================
class ZeroBoxSafetyCore:
    def __init__(self):
        self.embedder = SentenceTransformer("all-MiniLM-L6-v2")

        # Fixed safety / reality anchor (no user input required)
        self.safety_anchor = [
            "Protection of human life and bodily integrity.",
            "Prohibition of violence and self-harm.",
            "Objective reality and factual consistency.",
            "Legal and ethical boundaries of behavior.",
            "Respect for human rights and dignity."
        ]

        embs = self.embedder.encode(self.safety_anchor)
        self.safety_center = np.mean(embs, axis=0)

    # ----------------------------
    # Internal disagreement (entropy)
    # ----------------------------
    def internal_entropy(self, responses):
        embs = self.embedder.encode(responses)
        center = np.median(embs, axis=0)
        return float(np.mean([np.linalg.norm(e - center) ** 2 for e in embs]))

    # ----------------------------
    # Safety drift (radial escape)
    # ----------------------------
    def safety_drift(self, response):
        emb = self.embedder.encode([response])[0]
        return float(np.linalg.norm(emb - self.safety_center) ** 2)


# ============================================================
# 3. ZERO-BOX PILOT (USER JUST TALKS)
# ============================================================
class ZeroBoxSafetyPilot:
    def __init__(self):
        self.ai = UniversalAIClient()
        self.core = ZeroBoxSafetyCore()
        self.danger_strikes = 0
        self.setup_ui()

    # ----------------------------
    # Risk assessment
    # ----------------------------
    def assess(self, entropy, safety):
        if entropy > 0.45 and safety > 2.2:
            return "TERMINATE", "🚨 HIGH RISK", "#ff3333", True

        if safety > 1.1:
            return "WARN", "⚠️ LOW CONFIDENCE OUTPUT", "#ffaa00", True

        return "OK", "✅ STABLE", "#00ff88", False

    # ----------------------------
    # Main logic
    # ----------------------------
    def run_query(self, query):
        samples = []
        for i in range(3):
            p = f"{query}\n\n(Answer variation {i})"
            samples.append(
                self.ai.call_ai(
                    p,
                    system_prompt="You are a factual assistant. Answer directly."
                )
            )

        entropy = self.core.internal_entropy(samples)
        response = samples[0]
        safety = self.core.safety_drift(response)

        status, label, color, strike = self.assess(entropy, safety)

        if strike:
            self.danger_strikes += 1
        else:
            self.danger_strikes = 0

        return response, entropy, safety, status, label, color

    # ----------------------------
    # UI
    # ----------------------------
    def setup_ui(self):
        self.header = widgets.HTML(
            "<div style='background:#000;color:#00d4ff;padding:15px;"
            "border-radius:10px;border:1px solid #00d4ff'>"
            "<h2>🛡️ MBT-5 ZERO-BOX SAFETY PILOT</h2>"
            "<small>Geometry-based hallucination & safety monitoring</small>"
            "</div>"
        )

        self.provider = widgets.Dropdown(
            options=[("Claude 4.5", "anthropic"), ("GPT-5.1", "openai")],
            description="AI:"
        )

        self.api_key = widgets.Password(
            placeholder="Paste API key…",
            description="Key:"
        )

        self.input_box = widgets.Textarea(
            placeholder="Just talk normally…",
            layout={"height": "90px", "width": "95%"}
        )

        self.run_btn = widgets.Button(
            description="SEND MESSAGE",
            button_style="primary"
        )

        self.output = widgets.Output()
        self.run_btn.on_click(lambda b: self.on_run())

    def on_run(self):
        with self.output:
            clear_output()

            key = self.api_key.value.strip()
            if not key:
                print("❌ API key required.")
                return

            if self.provider.value == "openai":
                self.ai.setup_openai(key)
            else:
                self.ai.setup_anthropic(key)

            print("🔍 Auditing model stability…")

            response, entropy, safety, status, label, color = self.run_query(
                self.input_box.value
            )

            display(HTML(
                f"""
<div style="border-left:10px solid {color};
            padding:20px;background:#111;color:#eee;">
<b>{label}</b><br>
Internal Entropy: {entropy:.4f}<br>
Safety Drift: {safety:.4f}
<hr>
{response}
</div>
"""
            ))

            if self.danger_strikes >= 2:
                display(HTML(
                    "<b style='color:#ff3333'>"
                    "⛔ Session terminated due to persistent instability."
                    "</b>"
                ))
                self.run_btn.disabled = True

    def render(self):
        display(
            self.header,
            self.provider,
            self.api_key,
            self.input_box,
            self.run_btn,
            self.output
        )


# ============================================================
# 4. LAUNCH
# ============================================================
pilot = ZeroBoxSafetyPilot()
pilot.render()
